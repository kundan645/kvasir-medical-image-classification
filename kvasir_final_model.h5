al_loss: 0.4200\n","Epoch 6/15\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 614ms/step - accuracy: 0.8411 - loss: 0.3912\n","Epoch 6: val_accuracy improved from 0.83250 to 0.83938, saving model to best_model.h5\n"]},{"name":"stderr","output_type":"stream","text":["WARNING:absl:You are saving your model as an HDF5 file via `model.save()` or `keras.saving.save_model(model)`. This file format is considered legacy. We recommend using instead the native Keras format, e.g. `model.save('my_model.keras')` or `keras.saving.save_model(model, 'my_model.keras')`. \n"]},{"name":"stdout","output_type":"stream","text":["\n","Epoch 6: finished saving model to best_model.h5\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m138s\u001b[0m 691ms/step - accuracy: 0.8458 - loss: 0.3853 - val_accuracy: 0.8394 - val_loss: 0.4171\n","Epoch 7/15\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 611ms/step - accuracy: 0.8558 - loss: 0.3492\n","Epoch 7: val_accuracy did not improve from 0.83938\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m137s\u001b[0m 683ms/step - accuracy: 0.8467 - loss: 0.3628 - val_accuracy: 0.8344 - val_loss: 0.4068\n","Epoch 8/15\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 612ms/step - accuracy: 0.8520 - loss: 0.3686\n","Epoch 8: val_accuracy did not improve from 0.83938\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m137s\u001b[0m 685ms/step - accuracy: 0.8591 - loss: 0.3639 - val_accuracy: 0.8269 - val_loss: 0.4467\n","Epoch 9/15\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 612ms/step - accuracy: 0.8564 - loss: 0.3440\n","Epoch 9: val_accuracy did not improve from 0.83938\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m137s\u001b[0m 686ms/step - accuracy: 0.8555 - loss: 0.3443 - val_accuracy: 0.8281 - val_loss: 0.4458\n","Epoch 10/15\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 609ms/step - accuracy: 0.8605 - loss: 0.3487\n","Epoch 10: val_accuracy did not improve from 0.83938\n","\u001b[1m200/200\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m137s\u001b[0m 685ms/step - accuracy: 0.8602 - loss: 0.3412 - val_accuracy: 0.8331 - val_loss: 0.4122\n","Epoch 10: early stopping\n","Restoring model weights from the end of the best epoch: 6.\n"]}],"source":["callbacks = [\n","    EarlyStopping(monitor='val_accuracy', patience=4,\n","                  restore_best_weights=True, verbose=1),\n","    ModelCheckpoint('best_model.h5', monitor='val_accuracy',\n","                    save_best_only=True, verbose=1)\n","]\n","\n","print(\"Training started 🚀\")\n","history = model.fit(\n","    train_gen,\n","    validation_data=val_gen,\n","    epochs=EPOCHS,\n","    callbacks=callbacks\n",")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"lJcdyyLS7M-T"},"outputs":[{"data":{"image/png":"\n","text/plain":["\u003cFigure size 1200x400 with 2 Axes\u003e"]},"metadata":{},"output_type":"display_data"}],"source":["plt.figure(figsize=(12,4))\n","\n","plt.subplot(1,2,1)\n","plt.plot(history.history['accuracy'], label='Train')\n","plt.plot(history.history['val_accuracy'], label='Val')\n","plt.title('Accuracy')\n","plt.legend()\n","\n","plt.subplot(1,2,2)\n","plt.plot(history.history['loss'], label='Train')\n","plt.plot(history.history['val_loss'], label='Val')\n","plt.title('Loss')\n","plt.legend()\n","\n","plt.show()\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"kuaU8QOs7oz6"},"outputs":[{"name":"stdout","output_type":"stream","text":["\u001b[1m50/50\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m19s\u001b[0m 294ms/step\n"]},{"data":{"image/png":"\n","text/plain":["\u003cFigure size 1000x800 with 2 Axes\u003e"]},"metadata":{},"output_type":"display_data"},{"name":"stdout","output_type":"stream","text":["                        precision    recall  f1-score   support\n","\n","    dyed-lifted-polyps       0.75      0.84      0.80       200\n","dyed-resection-margins       0.91      0.72      0.80       200\n","           esophagitis       0.83      0.67      0.74       200\n","          normal-cecum       0.86      0.95      0.90       200\n","        normal-pylorus       0.93      0.99      0.96       200\n","         normal-z-line       0.72      0.81      0.77       200\n","                polyps       0.84      0.81      0.82       200\n","    ulcerative-colitis       0.91      0.92      0.91       200\n","\n","              accuracy                           0.84      1600\n","             macro avg       0.84      0.84      0.84      1600\n","          weighted avg       0.84      0.84      0.84      1600\n","\n"]}],"source":["from sklearn.metrics import confusion_matrix, classification_report\n","import seaborn as sns\n","\n","val_gen.reset()\n","y_pred = model.predict(val_gen)\n","y_pred = np.argmax(y_pred, axis=1)\n","y_true = val_gen.classes\n","class_names = list(val_gen.class_indices.keys())\n","\n","cm = confusion_matrix(y_true, y_pred)\n","plt.figure(figsize=(10, 8))\n","sns.heatmap(cm, annot=True, fmt='d',\n","            xticklabels=class_names,\n","            yticklabels=class_names,\n","            cmap='Blues')\n","plt.title('Confusion Matrix')\n","plt.xlabel('Predicted')\n","plt.ylabel('Actual')\n","plt.xticks(rotation=45, ha='right')\n","plt.tight_layout()\n","plt.show()\n","\n","print(classification_report(y_true, y_pred, target_names=class_names))"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"31CXXfQ48IDx"},"outputs":[{"name":"stderr","output_type":"stream","text":["WARNING:absl:You are saving your model as an HDF5 file via `model.save()` or `keras.saving.save_model(model)`. This file format is considered legacy. We recommend using instead the native Keras format, e.g. `model.save('my_model.keras')` or `keras.saving.save_model(model, 'my_model.keras')`. \n"]},{"name":"stdout","output_type":"stream","text":["Model saved to Google Drive! ✅\n"]}],"source":["model.save(\"/content/drive/MyDrive/kvasir_final_model.h5\")\n","print(\"Model saved to Google Drive! ✅\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"pLzM2z5NCLWK"},"outputs":[{"name":"stdout","output_type":"stream","text":["✅ Graphs saved to Google Drive!\n"]},{"data":{"image/png":"\n","text/plain":["\u003cFigure size 1200x400 with 2 Axes\u003e"]},"metadata":{},"output_type":"display_data"}],"source":["plt.figure(figsize=(12,4))\n","\n","plt.subplot(1,2,1)\n","plt.plot(history.history['accuracy'], label='Train')\n","plt.plot(history.history['val_accuracy'], label='Val')\n","plt.title('Accuracy')\n","plt.legend()\n","\n","plt.subplot(1,2,2)\n","plt.plot(history.history['loss'], label='Train')\n","plt.plot(history.history['val_loss'], label='Val')\n","plt.title('Loss')\n","plt.legend()\n","\n","plt.savefig(\"/content/drive/MyDrive/kvasir_graphs.png\")\n","print(\"✅ Graphs saved to Google Drive!\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"GfBplOfQCP6E"},"outputs":[{"name":"stdout","output_type":"stream","text":["✅ Classification report saved!\n"]}],"source":["from sklearn.metrics import classification_report\n","import pandas as pd\n","\n","report = classification_report(y_true, y_pred,\n","                               target_names=class_names,\n","                               output_dict=True)\n","df = pd.DataFrame(report).transpose()\n","df.to_csv(\"/content/drive/MyDrive/kvasir_report.csv\")\n","print(\"✅ Classification report saved!\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"ICdVm30Amo4O"},"outputs":[],"source":["import numpy as np\n","import matplotlib.pyplot as plt\n","from tensorflow.keras.preprocessing import image\n","import random\n","import os\n","\n","# Pick a random image from dataset\n","class_names = list(val_gen.class_indices.keys())\n","\n","# Pick random class and random image\n","random_class = random.choice(class_names)\n","class_folder = f\"/content/KVASIR DATASET/kvasir-dataset-v2/{random_class}\"\n","random_image = random.choice(os.listdir(class_folder))\n","img_path = f\"{class_folder}/{random_image}\"\n","\n","# Load and preprocess image\n","img = image.load_img(img_path, target_size=(224, 224))\n","img_array = image.img_to_array(img) / 255.0\n","img_array = np.expand_dims(img_array, axis=0)\n","\n","# Predict\n","predictions = model.predict(img_array)[0]\n","predicted_class = class_names[np.argmax(predictions)]\n","confidence = np.max(predictions) * 100\n","\n","# Show result\n","plt.imshow(image.load_img(img_path))\n","plt.axis('off')\n","plt.title(f\"✅ Actual:    {random_class}\\n🤖 Predicted: {predicted_class}\\n💯 Confidence: {confidence:.1f}%\",\n","          fontsize=12)\n","plt.show()\n","\n","if predicted_class == random_class:\n","    print(\"✅ CORRECT! Model predicted right!\")\n","else:\n","    print(\"❌ WRONG! Model made a mistake!\")"]}],"metadata":{"accelerator":"GPU","colab":{"authorship_tag":"ABX9TyOxP6AfnVCbihLtyNbvuALl","gpuType":"T4","mount_file_id":"12V4JcEljO2i5yTPtWQQrh-Ex4p273hbO","name":"","version":""},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}